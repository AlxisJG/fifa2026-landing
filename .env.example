# =============================================================================
# Site URL — canonical, Open Graph y metadata SEO
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://fifa.piodeportes.com

# Google Search Console — verificación de propiedad del sitio
GOOGLE_SITE_VERIFICATION=7sAuRPcvupNqrIvNYcL-Bph8S19y7Tm_k_zU8umGkxA
# Post-deploy SEO: 1) Verificar propiedad en search.google.com/search-console
# 2) Enviar sitemap https://fifa.piodeportes.com/sitemap.xml
# 3) Monitorear Cobertura + Experiencia (Core Web Vitals) semanalmente

# =============================================================================
# SportMonks API v3 — datos de partidos, ticker, tabla y match center
# =============================================================================
# Copia este archivo a .env.local para desarrollo.
# En producción configura las mismas variables en tu hosting (Vercel, etc.).

# --- Producción (recomendado en Vercel/hosting) ---
# USE_REAL_FOOTBALL_DATA=true evita badge "Demo" y activa SportMonks en vivo.
USE_REAL_FOOTBALL_DATA=true
SPORTMONKS_SEASON_ID=26618

# --- Modo demo local (sin token SportMonks) ---
# USE_REAL_FOOTBALL_DATA=false

SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football
SPORTMONKS_SEASON_ID=

# Alias legacy (opcional). Preferir USE_REAL_FOOTBALL_DATA en server.
NEXT_PUBLIC_USE_REAL_FOOTBALL_DATA=false

# Verifica configuración: GET /api/football/status
# Respuesta: { provider: "sportmonks", mode, configured, missing, seasonId, baseUrl }

# Local con SportMonks (no mock): USE_REAL_FOOTBALL_DATA=true + token + SPORTMONKS_SEASON_ID=26618
# placeholder = campo TBD en respuestas SportMonks (no es modo demo local)
# SPORTMONKS_INCLUDE_ALL_FIXTURES=true — muestra todo el schedule, no solo próximos
# SPORTMONKS_PRIORITIZE_PLACEHOLDERS=true — ordena fixtures TBD primero en UI
# Validar: node scripts/validate-sportmonks.mjs | GET /api/football/status
# Guía WC 2026: https://docs.sportmonks.com/v3/world-cup-2026/how-to-build-your-world-cup-application

# =============================================================================
# Secciones en vivo (producción) — ticker, match center, stream, plantillas
# =============================================================================
# En producción las secciones en vivo requieren AMBAS condiciones:
#   1. ENABLE_FOOTBALL_LIVE_SECTIONS=true
#   2. Countdown terminado (11 jun 2026 20:00 AST)
# En desarrollo (npm run dev) siempre visibles para diseño / SportMonks.
ENABLE_FOOTBALL_LIVE_SECTIONS=false

# =============================================================================
# Ad slots — banners, skyscrapers, popup y sticky mobile
# =============================================================================
# Ocultos por defecto hasta tener inventario/creatives configurados.
# NEXT_PUBLIC_ENABLE_AD_SLOTS=true — muestra los slots placeholder en la UI.
NEXT_PUBLIC_ENABLE_AD_SLOTS=false

# =============================================================================
# Patrocinadores — wall de logos en home
# =============================================================================
# Oculto por defecto hasta subir los logos finales.
# NEXT_PUBLIC_ENABLE_SPONSOR_LOGOS=true
NEXT_PUBLIC_ENABLE_SPONSOR_LOGOS=false

# =============================================================================
# Meta (Facebook) Pixel — marketing / conversion tracking
# =============================================================================
# ID numérico desde Meta Events Manager → Orígenes de datos → Tu pixel → Configurar
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345

# =============================================================================
# Google Analytics 4 — tráfico web
# =============================================================================
# Admin de GA → Flujos de datos → Web → ID de medición (ej. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# Google Ads — remarketing y conversiones (gtag AW-)
# =============================================================================
# Google Ads → Herramientas → Configuración → Etiqueta de Google
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-967165184

# =============================================================================
# WordPress API (noticias y galería)
# =============================================================================
NEXT_PUBLIC_WP_API_URL=https://www.piodeportes.com/wp-json/fifapp/v1
# Noticias/galería: cache 5 min en Vercel CDN + Data Cache (src/lib/cache/wordpress.ts)
# Slug de categoría WordPress para noticias del Mundial (taxonomía category)
NEXT_PUBLIC_WP_NEWS_CATEGORY_SLUG=mundial-fifa-usa-can-mex-2026
# Slug de categoría WordPress (taxonomía category en attachments / medios)
NEXT_PUBLIC_WP_GALLERY_CATEGORY_SLUG=fifa2026galeria

# Respaldo si WordPress cae: última respuesta exitosa (src/lib/cache/wordpress-snapshot.ts)
# Local/dev: guarda en .wp-cache/ (gitignored) si Redis no está configurado.
# Producción (Vercel): Storage → Upstash Redis → conectar al proyecto.
# Vercel puede inyectar variables con prefijo del storage (ej. FIFAPIO_KV_*) o UPSTASH_REDIS_*.
# Para snapshots se usa el token de escritura (FIFAPIO_KV_REST_API_TOKEN), no el read-only.
# FIFAPIO_KV_REST_API_URL=
# FIFAPIO_KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# WP_SNAPSHOT_DIR=.wp-cache

# Brightcove — reproductor playlist en /highlights (opcional; hay URL por defecto)
# NEXT_PUBLIC_BRIGHTCOVE_HIGHLIGHTS_EMBED_URL=https://players.brightcove.net/6416149296001/default_default/index.html?playlistId=1867009149758593664

# Transmisión en vivo — requiere ENABLE_LIVE_TRANSMISSION=true Y señal activa en Brightcove
# para mostrar el botón En vivo y permitir acceso a /transmision
ENABLE_LIVE_TRANSMISSION=false

# Brightcove — transmisión en vivo (/transmision + botón En vivo)
# BRIGHTCOVE_LIVE_ACCOUNT_ID=6416149296001
#
# Stream 1 — Transmisión Live #1
# BRIGHTCOVE_LIVE_PLAYER_ID=nJQN4AMQl
# BRIGHTCOVE_LIVE_VIDEO_ID=6397475321112
# BRIGHTCOVE_LIVE_PLAYBACK_TOKEN=   # opcional — solo si el canal lo requiere
# BRIGHTCOVE_LIVE_MATCH_TITLE=Canal principal
# BRIGHTCOVE_LIVE_MATCH_SUBTITLE=Mundial FIFA 2026
#
# Stream 2 — Transmisión Live #2
# BRIGHTCOVE_LIVE_2_PLAYER_ID=nTLJhzrh9
# BRIGHTCOVE_LIVE_2_VIDEO_ID=6397679161112
# BRIGHTCOVE_LIVE_2_PLAYBACK_TOKEN=   # opcional
# BRIGHTCOVE_LIVE_2_MATCH_TITLE=Canal alterno
# BRIGHTCOVE_LIVE_2_MATCH_SUBTITLE=Mundial FIFA 2026
