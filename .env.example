# =============================================================================
# SportMonks API v3 — datos de partidos, ticker, tabla y match center
# =============================================================================
# Copia este archivo a .env.local para desarrollo.
# En producción configura las mismas variables en tu hosting (Vercel, etc.).

# --- Modo demo (actual) ---
# No hace llamadas a la API. Usa datos estáticos de src/data/worldcup-widgets.ts
USE_REAL_FOOTBALL_DATA=false

# --- Modo producción (cuando tengas el token) ---
# USE_REAL_FOOTBALL_DATA=true
# SPORTMONKS_API_TOKEN=tu_token_de_mysportmonks
# SPORTMONKS_SEASON_ID=id_temporada_mundial_2026

SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football
SPORTMONKS_SEASON_ID=

# Alias legacy (opcional). Preferir USE_REAL_FOOTBALL_DATA en server.
NEXT_PUBLIC_USE_REAL_FOOTBALL_DATA=false

# Verifica configuración: GET /api/football/status
# Respuesta: { provider: "sportmonks", mode, configured, missing, seasonId, baseUrl }

# Obtener SPORTMONKS_SEASON_ID: MySportmonks → league/tournament World Cup → seasons

# =============================================================================
# Meta (Facebook) Pixel — marketing / conversion tracking
# =============================================================================
# ID numérico desde Meta Events Manager → Orígenes de datos → Tu pixel → Configurar
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345

# =============================================================================
# Google Analytics 4 — tráfico web
# =============================================================================
# Admin de GA → Flujos de datos → Web → ID de medición (ej. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# WordPress FIFApp API (Auth, Products, Purchases)
# =============================================================================
NEXT_PUBLIC_WP_API_URL=https://tudominio.com/wp-json/fifapp/v1
